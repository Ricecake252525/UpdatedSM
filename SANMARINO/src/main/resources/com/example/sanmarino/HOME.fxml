<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" 
           prefHeight="1080.0" prefWidth="1920.0" stylesheets="@UI.css" 
           xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" 
           fx:controller="com.example.sanmarino.smUiController">
   
   <children>
      <ImageView fitHeight="1080.0" fitWidth="1920.0" pickOnBounds="true" preserveRatio="false">
         <image>
            <Image url="@BRGY.png" /> </image>
      </ImageView>

      <Rectangle fill="#000000" height="1080.0" opacity="0.4" width="1920.0" />

      <BorderPane>
         <top>
   <HBox alignment="CENTER" prefHeight="100.0" spacing="30.0" 
         style="-fx-background-color: rgba(0,0,0,0.5); -fx-padding: 20 0;">
      <children>
         
         <ImageView fitHeight="350.0" fitWidth="350.0" pickOnBounds="true" preserveRatio="true">
            <image>
               <Image url="@LOGO.png" />
            </image>
         </ImageView>
         
         <Rectangle fill="#148C9E" height="100.0" width="3.0" />

         <Label text="BRGY. SAN MARINO" textFill="WHITE">
            <font>
               <Font name="System Bold" size="55.0" />
            </font>
         </Label>
         </children>
         </HBox>
      </top>
         <center>
            <AnchorPane BorderPane.alignment="CENTER">
               <children>
                  <VBox layoutX="100.0" layoutY="200.0" spacing="10">
                     <children>
                        <Label fx:id="WELCOME" text="WELCOME," textFill="WHITE">
                           <font>
                              <Font name="System Bold" size="110.0" />
                           </font>
                        </Label>
                        <Label fx:id="WELCOME" text="USER!" textFill="WHITE">
                           <font>
                              <Font name="System Bold" size="110.0" />
                           </font>
                        </Label>
                        <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#148C9E" height="4.0" width="600.0" />
                     </children>
                  </VBox>

                  <VBox layoutX="1300.0" layoutY="150.0" prefWidth="400.0" spacing="2.0">
                     <children>
                        
                        <HBox alignment="CENTER_LEFT" onMouseClicked="#switchToAnnouncement" prefHeight="120.0" spacing="20.0" 
                              style="-fx-background-color: rgba(20, 140, 158, 0.9); -fx-cursor: hand; -fx-padding: 20;">
                           <children>
                              <Label text="📢" textFill="WHITE" style="-fx-font-size: 30;"/>
                              <Label text="ANNOUNCEMENTS" textFill="WHITE" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                           </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" onMouseClicked="#switchToRecords" prefHeight="120.0" spacing="20.0" 
                              style="-fx-background-color: rgba(20, 140, 158, 0.9); -fx-cursor: hand; -fx-padding: 20;">
                           <children>
                              <Label text="💳" textFill="WHITE" style="-fx-font-size: 30;"/>
                              <Label text="TRANSACTIONS" textFill="WHITE" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                           </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" onMouseClicked="#switchToAbout" prefHeight="120.0" spacing="20.0" 
                              style="-fx-background-color: rgba(20, 140, 158, 0.9); -fx-cursor: hand; -fx-padding: 20;">
                           <children>
                              <Label text="👥" textFill="WHITE" style="-fx-font-size: 30;"/>
                              <Label text="RESIDENTS" textFill="WHITE" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                           </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" prefHeight="120.0" spacing="20.0" 
                              style="-fx-background-color: rgba(20, 140, 158, 0.9); -fx-cursor: hand; -fx-padding: 20;">
                           <children>
                              <Label text="⍈" textFill="WHITE" style="-fx-font-size: 30;"/>
                              <Label text="LOGOUT" textFill="WHITE" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                           </children>
                        </HBox>

                     </children>
                  </VBox>
               </children>
            </AnchorPane>
         </center>
      </BorderPane>
   </children>
</StackPane>